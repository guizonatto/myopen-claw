# ==========================================
# 1. CÉREBRO PRINCIPAL (AI PROVIDER)
# Escolha a sua IA (Opções comuns: deepseek-api-key, openai-api-key, anthropic-api-key, openrouter-api-key)
# ==========================================
AUTH_CHOICE=deepseek-api-key
# Você precisa injetar o token na variável base correspondente abaixo:
DEEPSEEK_API_KEY=sk-xxxxxx
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
# OPENROUTER_API_KEY=...
# Modelo padrão do OpenRouter (muitos modelos gratuitos usam sufixo :free)
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# NVIDIA NIM (modelos via integrate.api.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxx
NVIDIA_MODEL=google/gemma-4-31b-it:latest
# ==========================================
# 2. CONFIGURAÇÃO DE GATEWAY (O PAINEL LOCAL DA APLICAÇÃO)
# ==========================================
# Expor o painel na sua rede local? (Responde a pergunta "Gateway Bind")
# "lan" te deixa acessar pelo navegador. "loopback" trava pra acesso interno só da maquina.
GATEWAY_BIND=lan
# Senha para acessar a interface visual
ADMIN_PASSWORD=senha_super_secreta
# ==========================================
# 3. SEGURANÇA AVANÇADA / SANDBOX E TOOLS
# ==========================================
# Ativar Sandbox MVM? (Responde a: "Use Sandbox/Docker for browser isolation?")
# Isola navegadores e agentes de código em containers separados para impedir ataques
ENABLE_SANDBOX=true
# Provider global barato do Web Search. Deixe `duckduckgo` como padrão e
# reserve Tavily para skills específicas de maior valor.
# Se você escolher um provider que exige API key (ex: `tavily`, `brave`, `firecrawl`)
# e a key estiver vazia, o gateway faz fallback automático para `duckduckgo`.
GLOBAL_WEB_SEARCH_PROVIDER=duckduckgo
# Compat (legado): alguns setups antigos ainda usam WEB_SEARCH_PROVIDER.
# Ele só é considerado quando GLOBAL_WEB_SEARCH_PROVIDER está vazio ou `duckduckgo`.
WEB_SEARCH_PROVIDER=
TAVILY_API_KEY=tvly-xxxxxx
BRAVE_API_KEY=
BRAVE_API_KEYS=
FIRECRAWL_API_KEY=fc-xxxxxx
# ==========================================
# 4. INSTALAÇÃO AUTOMÁTICA DE SKILLS (HABILIDADES)
# ==========================================
# Digite os nomes das skills que quer pré-instalar separados por espaço. 
# (Ex: x-trending weather coding-agent notion github)
AUTO_INSTALL_SKILLS="coding-agent "
# ==========================================
# 5. CONECTORES DE CANAIS (MENSAGEIROS)
# ==========================================
# -- TELEGRAM --
# Para desativar, deixe o token vazio
TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
# ID Numérico de segurança (equivale a permitir DM no Setup Interativo)
TELEGRAM_USER_ID=00000000
# -- DISCORD --
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Canais específicos por conteúdo
DISCORD_CHANNEL_ID=
# -- SLACK --
# Precisa das duas chaves preenchidas para ativar
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# -- WHATSAPP --
# true/false (lembrando que você terá que abrir `docker compose logs` e escanear o QRCode na primeira vez)
ENABLE_WHATSAPP=false
# Número do owner para receber escalações da skill usell-sales-workflow (DDI+DDD+número)
OWNER_WHATSAPP=5541999159953
# -- EVOLUTION API (WhatsApp bot de vendas) --
EVOLUTION_URL=http://openclaw-evolution-api:8080
EVOLUTION_INSTANCE=nome-da-instancia
EVOLUTION_API_KEY=sua-chave-aqui
# Número de telefone do WhatsApp da instância Usell (DDI+DDD+número, sem +)
USELL_WHATSAPP_PHONE=554163470650
CRON_TZ=America/Sao_Paulo
SKILLS_GIT_REPO=YOUR_REPOSITORY_URL_HERE
# ==========================================
# 6. MEMÓRIA DE LONGO PRAZO
# ==========================================
# Cortex-Mem — serviço HTTP usado pelo plugin MemClaw
CORTEX_MEM_URL=http://cortex-mem:8085
# LLM do Cortex-Mem e do MemClaw para extracao, sumarizacao e geracao de L0/L1.
# Nao e o endpoint de embeddings.
ZAI_API_KEY=sk-xxxxxx
ZAI_API_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=GLM-4.7
# Ollama — LLM + embeddings rodando no host (fora do Docker).
# Containers acessam via host.docker.internal:11434 (Docker Desktop no Windows/Mac).
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama-local
OLLAMA_MODEL=gemma4
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIM=1024
MODEL_USAGE_PROXY_ENABLED=true
MODEL_USAGE_PROXY_ROOT=http://llm-metrics-proxy:8080
MODEL_USAGE_PROXY_URL=http://llm-metrics-proxy:8080/openclaw
MODEL_USAGE_PROXY_TOKEN=usage-router-local
MODEL_USAGE_CAPTURE_PAYLOADS=full
MODEL_USAGE_ESTIMATE_CHAT_TOKENS=false
GOOGLE_AUTH_MODE=gemini_api
# Gemini API / AI Studio (free tier): use GEMINI_API_KEY with Bearer auth against
# https://generativelanguage.googleapis.com/v1beta/openai
# For Vertex AI OpenAI-compat, set GOOGLE_AUTH_MODE=vertex_oauth and provide:
# GOOGLE_OAUTH_TOKEN=ya29...
# GOOGLE_OPENAI_BASE_URL=https://aiplatform.googleapis.com/v1/projects/PROJECT/locations/global/endpoints/openapi
MODEL_USAGE_REPORT_TIMEZONE=America/Sao_Paulo
MODEL_USAGE_REPORT_DISCORD_CHANNEL_ID=
MODEL_USAGE_RETENTION_DAYS=30
# ==========================================
# 7. MISSION CONTROL (abhi1693/openclaw-mission-control)
# ==========================================
OPENCLAW_GATEWAY_TOKEN=   # Bearer token WebSocket para o gateway (opcional)
MC_AUTH_TOKEN=            # Token de acesso ao Mission Control (mínimo 50 caracteres, obrigatório)
# ==========================================
# 8. BACKUP (Google Drive via rclone)
# ==========================================
# 1. Instale rclone: https://rclone.org/install/
# 2. Configure: rclone config → escolha Google Drive → gere rclone.conf
# 3. Crie uma pasta no Drive e cole o ID aqui (parte final da URL da pasta)
GDRIVE_FOLDER_ID=               # ID da pasta no Google Drive para backups
BACKUP_ENABLED=true             # "false" para desabilitar o cron de backup
BACKUP_RETENTION_DAYS=7         # Dias de retenção de backups remotos
DISCORD_ALERT_CHANNEL_ID=       # ID do canal Discord para alertas de erro de backup
# ==========================================
# 9. GITHUB (push automático de skills e documentação)
# ==========================================
# -- GITHUB (push automático de skills e documentação) --
GITHUB_TOKEN=ghp_xxxxxx
GITHUB_ORG=sua-org-ou-usuario
GITHUB_REPO=myopen-claw
# -- OBSIDIAN VAULT (sincronização git automática) --
OBSIDIAN_GIT_REPO=https://github.com/guizonatto/obsidian
OBSIDIAN_VAULT_PATH=/vault
GIT_USER_EMAIL=guizonatto@gmail.com
GIT_USER_NAME=guizonatto
# ==========================================
