{
  "$schema": "https://docs.openclaw.ai/schema.json",
  "mcp": {
    "servers": {
      "mcp-crm": {
        "command": "docker",
        "args": [
          "exec",
          "-i",
          "mcp-crm",
          "python3",
          "/app/main.py"
        ],
        "type": "stdio"
      },
      "mcp-shopping": {
        "command": "docker",
        "args": [
          "exec",
          "-i",
          "mcp-shopping-tracker",
          "python3",
          "/app/main.py"
        ],
        "type": "stdio"
      },
      "mcp-leads": {
        "command": "docker",
        "args": [
          "exec",
          "-i",
          "mcp-leads",
          "python3",
          "/app/main.py"
        ],
        "type": "stdio"
      },
      "mcp-trends": {
        "command": "docker",
        "args": [
          "exec",
          "-i",
          "mcp-trends",
          "python3",
          "/app/main.py"
        ],
        "type": "stdio"
      },
      "obsidian": {
        "command": "npx",
        "args": [
          "-y",
          "obsidian-mcp",
          "/vault"
        ],
        "type": "stdio"
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "memclaw"
    },
    "entries": {
      "memclaw": {
        "enabled": true,
        "config": {
          "serviceUrl": "${CORTEX_MEM_URL:-http://cortex-mem:8085}",
          "tenantId": "tenant_claw",
          "autoStartServices": false,
          "llmApiBaseUrl": "${ZAI_API_BASE_URL:-https://api.z.ai/api/paas/v4}",
          "llmApiKey": "${ZAI_API_KEY}",
          "llmModel": "${ZAI_MODEL:-GLM-4.7}",
          "embeddingApiBaseUrl": "http://host.docker.internal:11434/v1",
          "embeddingApiKey": "ollama",
          "embeddingModel": "${EMBEDDING_MODEL:-qwen3-embedding:0.6b}"
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "auth": {
      "token": "senhaSecretaDoGuizo123"
    }
  },
  "browser": {
    "enabled": true
  },
  "tools": {
    "web": {
      "fetch": {
        "enabled": true
      },
      "search": {
        "provider": "duckduckgo"
      }
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "skills": {
    "entries": {
      "tech-news-digest": {
        "env": {
          "WEB_SEARCH_BACKEND": "tavily"
        }
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "apiKey": "ollama-local",
        "baseUrl": "http://host.docker.internal:11434",
        "api": "ollama",
        "models": []
      },
      "usage-router": {
        "baseUrl": "http://llm-metrics-proxy:8080/openclaw/v1",
        "apiKey": "usage-router-local",
        "api": "openai-completions",
        "models": []
      }
    }
  },
  "agents": {
    "defaults": {
      "memorySearch": {
        "enabled": false
      },
      "model": {
        "primary": "usage-router/groq/llama-3.1-8b-instant",
