{
  "$schema": "https://docs.openclaw.ai/schema.json",
  "mcp": {
    "servers": {
      "mcp-crm": {
        "command": "docker",
        "args": ["exec", "-i", "mcp-crm", "python3", "/app/main.py"],
        "type": "stdio"
      },
      "mcp-memories": {
        "command": "docker",
        "args": ["exec", "-i", "mcp-memories", "python3", "/app/main.py"],
        "type": "stdio"
      },
      "mcp-shopping": {
        "command": "docker",
        "args": ["exec", "-i", "mcp-shopping-tracker", "python3", "/app/main.py"],
        "type": "stdio"
      },
      "mcp-trends": {
        "command": "docker",
        "args": ["exec", "-i", "mcp-trends", "python3", "/app/main.py"],
        "type": "stdio"
      }
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "auth": {
      "token": "senhaSecretaDoGuizo123"
    }
  },
  "browser": {
    "enabled": true
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "agents": {
    "list": [
      {
        "id": "default",
        "default": true,
        "workspace": "~/.openclaw/workspace"
      },
      {
        "id": "usell",
        "name": "Usell Sales",
        "workspace": "~/.openclaw/workspace",
        "tools": {
          "profile": "messaging"
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "default",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "5541999159953" }
      }
    },
    {
      "agentId": "usell",
      "match": {
        "channel": "whatsapp"
      }
    }
  ],
  "logging": {
    "level": "debug"
  }
}
